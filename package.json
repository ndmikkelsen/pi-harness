{
  "name": "pi-harness",
  "version": "0.1.0",
  "description": "Modular CLI for bootstrapping AI workflow project scaffolding.",
  "type": "module",
  "bin": {
    "pi-harness": "dist/src/cli.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "dev": "tsx src/cli.ts",
    "install:local": "tsx scripts/install-local-launcher.ts",
    "test": "vitest run",
    "test:bdd": "vitest run --config vitest.bdd.config.ts",
    "test:bdd:watch": "vitest --config vitest.bdd.config.ts",
    "test:watch": "vitest",
    "test:smoke:dist": "pnpm build && node scripts/dist-smoke.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "6.2.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.33.0"
}
