    ".planning/quick/README.md",
    ".planning/research/README.md",
    ".pre-commit-config.yaml",
    ".rules/index.md",
    ".rules/patterns/bdd-workflow.md",
    ".rules/patterns/beads-integration.md",
    ".rules/patterns/cognee-gsd-integration.md",
