    ".codex/scripts/cognee-sync-planning.sh",
    ".codex/scripts/land.sh",
    ".codex/scripts/sync-planning-to-cognee.sh",
    ".codex/skills/scaiff-repo-setup/SKILL.md",
    ".codex/skills/scaiff-repo-setup/assets/adoption-notes-template.md",
    ".codex/skills/scaiff-repo-setup/references/existing-repo-context-checklist.md",
    ".codex/skills/scaiff-repo-setup/references/manifest-discovery.md",
    ".codex/skills/scaiff-repo-setup/references/scaffold-customization-map.md",
    ".codex/skills/scaiff-repo-setup/references/scaiff-command-matrix.md",
    ".codex/templates/phase-execution.md",
    ".codex/workflows/parallel-execution.md",
    ".env.example",
    ".envrc",
