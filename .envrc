# direnv file for local, machine-specific secrets.
# Run: direnv allow

# Optional: only set this when your Dolt server requires authentication.
# export BEADS_DOLT_PASSWORD="CHANGE_ME_DOLT_PASSWORD"

# Mirror the local GitHub token helper only when it is explicitly set.
if [[ -n "${_GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]]; then
  export GITHUB_PERSONAL_ACCESS_TOKEN="$_GITHUB_PERSONAL_ACCESS_TOKEN"
fi
