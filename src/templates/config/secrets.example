# Copy this file to .kamal/secrets and replace every placeholder.
# Real secrets belong in local environment management, never in git.

KAMAL_REGISTRY_PASSWORD=YOUR_HARBOR_REGISTRY_PASSWORD_HERE
COGNEE_DB_PASSWORD=YOUR_COGNEE_DB_PASSWORD_HERE
DB_PASSWORD=YOUR_COGNEE_DB_PASSWORD_HERE
VECTOR_DB_PASSWORD=YOUR_COGNEE_DB_PASSWORD_HERE
POSTGRES_PASSWORD=YOUR_COGNEE_DB_PASSWORD_HERE
RELATIONAL_DATABASE=postgresql://cognee:YOUR_COGNEE_DB_PASSWORD_HERE@{{APP_SLUG}}-cognee-db:5432/cognee
VECTOR_DB_URL=postgresql://cognee:YOUR_COGNEE_DB_PASSWORD_HERE@{{APP_SLUG}}-cognee-db:5432/cognee
LLM_API_KEY=YOUR_OPENAI_API_KEY_HERE
